# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret_here

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=arknova
DB_USER=arknova
DB_PASS=changeme_strong_password_here
# Full JDBC URL (used by bot)
DATABASE_URL=postgresql://arknova:changeme_strong_password_here@db:5432/arknova

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Image Storage ─────────────────────────────────────────────────────────────
# Local filesystem path inside the bot container
IMAGE_STORAGE_PATH=/app/images
# Optional: Cloudflare R2 (leave blank to use local storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Web / Auth ────────────────────────────────────────────────────────────────
# Used for Discord OAuth on the web frontend
WEB_BASE_URL=http://localhost:3000
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long

# ─── Bot Settings ──────────────────────────────────────────────────────────────
# Spring Boot server port (internal; nginx proxies externally)
SERVER_PORT=8080
# Enable debug logging (true/false)
DEBUG_LOGGING=false
